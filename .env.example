# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Database Connection (Neon PostgreSQL free tier)
DATABASE_URL="postgresql://user:password@endpoint.neon.tech/neondb"

# Authentication Secret
NEXTAUTH_SECRET="my_super_secret_for_jwt"

# Resend API Key for Email reminders (Optional)
RESEND_API_KEY=""
MANAGER_EMAIL="admin@gymdesk.com"
